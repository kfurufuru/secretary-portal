#!/usr/bin/env bash
# pre-commit: secret leak detection
# 検知パターン: Groq / Google / OpenAI / Notion / Slack / GitHub PAT / AWS

set -e

PATTERNS='(gsk_[A-Za-z0-9]{40,}|AIza[0-9A-Za-z_-]{35}|sk-[A-Za-z0-9]{40,}|sk-proj-[A-Za-z0-9_-]{40,}|ntn_[A-Za-z0-9]{40,}|xoxb-[A-Za-z0-9-]{40,}|ghp_[A-Za-z0-9]{36}|ghs_[A-Za-z0-9]{36}|AKIA[0-9A-Z]{16})'

# stagedファイルから検知
HITS=$(git diff --cached --no-color -U0 | grep -E "^\+" | grep -E "$PATTERNS" || true)

if [ -n "$HITS" ]; then
  echo "" >&2
  echo "🚨 SECRET LEAK BLOCKED — pre-commit hook" >&2
  echo "" >&2
  echo "以下のパターンに該当する文字列が staged な変更に含まれています:" >&2
  echo "$HITS" | head -10 >&2
  echo "" >&2
  echo "対処:" >&2
  echo "  1. 環境変数経由に変更（os.environ.get(\"KEY\", \"\") でフォールバック空文字）" >&2
  echo "  2. 既にコミット済みなら即キー失効＋ git filter-repo で履歴スクラブ" >&2
  echo "  3. 緊急回避: git commit --no-verify （非推奨。漏洩即発生）" >&2
  echo "" >&2
  exit 1
fi

# ============================================================
# (2) denken-(hoki|3-riron)-wiki.html: audit + Babel構文チェック
# ============================================================
staged=$(git diff --cached --name-only)

if echo "$staged" | grep -q "^denken-hoki-wiki\.html$"; then
    echo "[pre-commit] denken-hoki-wiki.html 変更検出 → audit 実行..."
    if ! python denken_hoki_audit.py --quiet; then
        echo ""
        echo "[pre-commit] ✗ FAIL: 'python denken_hoki_audit.py' で詳細確認"
        echo "[pre-commit] 緊急回避: git commit --no-verify （非推奨）"
        exit 1
    fi
    echo "[pre-commit] ✓ audit PASS"
fi

# ============================================================
# (3) アクティブ編集ロックチェック（並列セッション衝突防止）
# ============================================================
if [ -f inbox/active-edits.md ] && [ -f claim_edit.py ]; then
    blocked=0
    for f in $staged; do
        if python claim_edit.py check --target "$f" --not-mine 2>/dev/null; then
            blocked=1
            echo "[pre-commit] ⚠ '$f' は別セッションが claim 中（上記参照）"
        fi
    done
    if [ "$blocked" = "1" ]; then
        echo ""
        echo "[pre-commit] ✗ FAIL: 別セッションの編集中ファイルを commit しようとしています"
        echo "  対処1: 別セッション完了を待つ（python claim_edit.py list で確認）"
        echo "  対処2: 自分が claim している場合は --session で同じIDを指定"
        echo "  対処3: 緊急回避（非推奨）: git commit --no-verify"
        exit 1
    else
        echo "[pre-commit] ✓ アクティブな別セッションなし（claim 衝突 0 件）"
    fi
fi

# Babel構文チェック（読み込み停止事故の再発防止：2026-05-03 L4567 a:キー欠落事案）
if echo "$staged" | grep -qE "^denken-(hoki|3-riron)-wiki\.html$"; then
    if curl -sf -o /dev/null -m 2 "http://localhost:8092/"; then
        targets=""
        echo "$staged" | grep -q "^denken-hoki-wiki\.html$"   && targets="$targets hoki"
        echo "$staged" | grep -q "^denken3-riron-wiki\.html$" && targets="$targets riron"
        for t in $targets; do
            echo "[pre-commit] babel_check.py $t 実行..."
            if ! python babel_check.py $t; then
                echo ""
                echo "[pre-commit] ✗ Babel構文エラー検出。修正してから再commit"
                echo "[pre-commit] 緊急回避: git commit --no-verify （非推奨）"
                exit 1
            fi
        done
        echo "[pre-commit] ✓ babel_check PASS"
    else
        echo "[pre-commit] ⚠ dev-server (8092) 未起動 → babel_check スキップ"
        echo "[pre-commit]   推奨: 'python dev-server.py 8092 .' 起動後に再commit"
    fi
fi

# ============================================================
# (5) 巻き戻り検出: staged 名前リストにあるが実差分0件のファイルを検出
#     並列セッションの git reset --hard / Obsidian同期で
#     私のEditが消失したケースを検知する
#     根拠: 2026-05-03 並列セッション衝突事故（claude-code-guide.html リバート）
# ============================================================
if [ -n "$staged" ]; then
    reverted=""
    for f in $staged; do
        # --numstat: "<追加> <削除> <ファイル>"。バイナリは "- - <ファイル>"
        line=$(git diff --cached --numstat -- "$f" 2>/dev/null)
        added=$(echo "$line" | awk '{print $1}')
        deleted=$(echo "$line" | awk '{print $2}')
        # 数値かつ両方0なら no-op staging（巻き戻り疑い）
        if [ "$added" = "0" ] && [ "$deleted" = "0" ]; then
            reverted="$reverted $f"
        fi
    done
    if [ -n "$reverted" ]; then
        echo ""
        echo "[pre-commit] 🚨 巻き戻り検出: 以下のファイルは staged だが実差分0件"
        for f in $reverted; do
            echo "  - $f"
        done
        echo ""
        echo "  原因の可能性:"
        echo "    1. 並列Claudeセッションが git reset --hard を実行"
        echo "    2. Obsidian同期 / 外部エディタによる巻き戻り"
        echo "    3. mode-only change（権限ビット変更のみ）"
        echo ""
        echo "  対処:"
        echo "    1. python claim_edit.py list で並列セッション確認"
        echo "    2. Edit を再適用してから git diff --stat <file> で差分確認"
        echo "    3. mode-only が意図なら git update-index --chmod=+x <file>"
        echo "  緊急回避（非推奨）: git commit --no-verify"
        exit 1
    fi
fi

exit 0
